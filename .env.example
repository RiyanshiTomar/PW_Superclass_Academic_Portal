# Copy this file to `.env` and fill in your Supabase project values.
# In Vercel, add these as Environment Variables (Project → Settings → Environment Variables).

# Supabase project URL (Supabase → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase anon/public key (Supabase → Project Settings → API → anon public)
# Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Supabase → Project Settings → API → service_role)
# SECRET — used only by the local data-import scripts (scripts/import-portal-data.js).
# Do NOT expose to the browser. Not required for the app to run/deploy.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
